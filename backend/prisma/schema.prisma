generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  DRIVER
  ADMIN
}

enum AuthProvider {
  LOCAL
  MICROSOFT
  GOOGLE
}

enum ListingType {
  SELL
  RENT
}

enum ProductStatus {
  AVAILABLE
  OUT_OF_STOCK
  SOLD_OUT
  RENTED_OUT
}

enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum NotificationType {
  CHAT_MESSAGE
  INTEREST_REQUEST
  SYSTEM_ALERT
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String?      
  name           String?
  role           Role         @default(STUDENT)
  
  provider       AuthProvider @default(LOCAL)
  externalId     String?      @unique 
  
  bio            String?
  profilePicture String?
  contactNumber  String?
  isVerified     Boolean    @default(false)
  
  products       Product[]  @relation("UserProducts")
  interests      Interest[] @relation("UserInterests")
  
  // Chat & Notifications
  conversationsAsBuyer  Conversation[] @relation("BuyerConversations")
  conversationsAsSeller Conversation[] @relation("SellerConversations")
  sentMessages          Message[]      @relation("SentMessages")
  notifications         Notification[] @relation("UserNotifications")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Bus {
  id              Int        @id @default(autoincrement())
  busNumber       String     @unique
  status          String     @default("INACTIVE")
  lat             Float?
  lng             Float?
  currentDriverId String?    @unique
  lastUpdated     DateTime   @updatedAt
  
  driverName      String?
  driverContact   String?
  
  schedules       Schedule[] 
}

model BusStop {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  lat         Float
  lng         Float
  
  departures  Schedule[] @relation("SourceStop")
  arrivals    Schedule[] @relation("DestStop")
}

model Schedule {
  id            Int      @id @default(autoincrement())
  departureTime String   
  
  busId         Int
  bus           Bus      @relation(fields: [busId], references: [id])
  
  sourceId      Int
  source        BusStop  @relation("SourceStop", fields: [sourceId], references: [id])
  
  destId        Int
  dest          BusStop  @relation("DestStop", fields: [destId], references: [id])
  
  dayType       String   @default("WEEKDAY")
}

model Product {
  id            String        @id @default(uuid())
  sellerId      String
  title         String
  description   String        @db.Text
  price         Float
  listingType   ListingType
  stockQuantity Int           @default(1)
  status        ProductStatus @default(AVAILABLE)
  images        String[]      
  
  seller        User          @relation("UserProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  interests     Interest[]    @relation("ProductInterests")
  conversations Conversation[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([sellerId])
  @@index([status, listingType]) 
}

model Interest {
  id        String         @id @default(uuid())
  productId String
  buyerId   String
  status    InterestStatus @default(PENDING)
  message   String?        @db.Text
  
  product   Product        @relation("ProductInterests", fields: [productId], references: [id], onDelete: Cascade)
  buyer     User           @relation("UserInterests", fields: [buyerId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, buyerId])
  @@index([productId])
  @@index([buyerId])
}

model Conversation {
  id        String    @id @default(uuid())
  productId String
  buyerId   String
  sellerId  String
  
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  
  messages  Message[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([productId, buyerId, sellerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String       @db.Text
  isRead         Boolean      @default(false)
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?          // e.g. /chats/:id or /marketplace/:id
  isRead    Boolean          @default(false)
  
  createdAt DateTime         @default(now())
}