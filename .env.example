# ==========================================
# DATABASE CONFIG (For Docker & Prisma)
# ==========================================
DB_USER=xxxxxx
DB_PASSWORD=xxxxxxx
DB_NAME=xxxxxx
DB_PORT=5432

# This URL is used by Prisma. 
# Note: "db" matches the service name in your docker-compose.yml
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}?schema=public"

# ==========================================
# AUTHENTICATION (For JWT)
# ==========================================
# Use a long, random string. Do not share this!
JWT_SECRET=your_super_secret_random_string_here_2026
JWT_EXPIRES_IN=7d

# ==========================================
# BACKEND CONFIG
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# FRONTEND CONFIG
# ==========================================
# If using Next.js, variables must start with NEXT_PUBLIC_ to be available on the client
API_URL=http://localhost:5000

